# Local dev environment for eu-ai-act-dataset.
#
# Copy to .env and fill in. None of these are required for `build` or
# `validate`; only `publish` needs HF_TOKEN.

# Hugging Face write token — https://huggingface.co/settings/tokens
HF_TOKEN=

# Target dataset repo (also overridable via --repo on the CLI)
HF_REPO=your-hf-username/eu-ai-act-2024-1689

# Override the Cellar polling timeout (seconds). The Publications Office
# can be slow to warm its branch-notice cache; bump if CI fails on 202.
CELLAR_MAX_WAIT_S=180
